# Streamlit secrets template.
# Copy to `.streamlit/secrets.toml` for local use, OR paste these keys into the
# Streamlit Community Cloud "Secrets" UI for the deployed app.
# NEVER commit the real secrets.toml (it is gitignored).

# MongoDB Atlas connection string (required on cloud to fetch the DuckDB file).
MONGO_URI = "mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority"

# Optional overrides (defaults shown):
# MONGO_DB_NAME = "smartbeta"
# MONGO_GRIDFS_BUCKET = "duckdb_store"
# MONGO_DUCKDB_FILE = "market_data.duckdb"
